{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Agent(*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session_start.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/post_push_pr_check.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python .claude/hooks/deprecation_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/eodhd_rebuild_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/ac_staleness_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/fix_commit_smell_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/spec_staleness_guard.py",
            "timeout": 20
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/assert_verify_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/artifact_path_guard.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/shellcheck_write_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/library_intro_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/retro_area_overlap_guard.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/main_branch_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/git_commit_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/deploy_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/merged_pr_guard.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python .claude/hooks/workaround_guard.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python .claude/hooks/mock_test_guard.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python .claude/hooks/prices_scan_guard.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python .claude/hooks/stderr_suppression_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/plan_config_drift_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/branch_from_main_guard.py",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "python .claude/hooks/pre_push_merged_branch_guard.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python .claude/hooks/cherry_pick_guard.py",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "python .claude/hooks/plan_commit_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/dotnet_process_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/constant_change_test_guard.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python .claude/hooks/js_module_coverage_guard.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python .claude/hooks/api_integration_test_gate.py",
            "timeout": 130
          },
          {
            "type": "command",
            "command": "python .claude/hooks/browser_compat_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/js_coordinate_truthiness_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/commit_claim_verify_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/plan_api_url_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/js_dead_assignment_guard.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python .claude/hooks/prod_target_verify_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/pr_migration_checklist.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python .claude/hooks/endpoint_registry_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python .claude/hooks/endpoint_schema_validator.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
