# Sensitive files - never commit
tokens.md
.env
.secrets/
*.key
*.pem
credentials.*
appsettings.Development.json

# OS files
.DS_Store
Thumbs.db

# IDE folders
.vscode/
.idea/

# Claude Code local settings (except hooks — those are version-controlled)
.claude/hooks/settings.json
.claude/settings.local.json
.claude/history/
.claude/logs/
.claude/cache/

# Python cache and virtual environments
__pycache__/
*.pyc
*.pyo
*-env/

# Theme generator test output
helpers/generated_theme.json
helpers/refined_theme.json

# Log and temp files
*.log
*_output.txt
slack_inbox.json
nul
yolov8n.pt

# Jenkins config (contains credentials)
jenkins-credentials.xml
jenkins-job-config.xml

# Slack bot runtime files
slack_acknowledged.json
slack_bot_pids.json
slack_last_sync.txt

# .NET build artifacts
**/bin/
**/obj/

# Audit reports (local only)
audit_reports/

# Git worktrees
.worktrees/

# Temp/debug files at root (not committed)
*.png
*.jpg
*.zip
app-logs/
app-logs-*/
slack_downloads/
slack_attachments/
*.ps1
*.md
