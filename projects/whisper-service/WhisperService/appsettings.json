{
  "Whisper": {
    "ModelPath": "models",
    "ModelSize": "base",
    "Language": "en",
    "SampleRate": 16000,
    "MinRecordingSeconds": 0.5,
    "MaxRecordingSeconds": 60
  },
  "Hotkeys": {
    "ToggleKey": "F24",
    "HoldModifiers": ["Control", "Alt"],
    "HoldKey": "V"
  },
  "Output": {
    "Mode": "PasteAndEnter",
    "ClipboardDelayMs": 200,
    "EnterDelayMs": 100
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
